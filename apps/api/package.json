{
  "name": "@chainatlas/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "npx wrangler dev --config wrangler.toml",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "deploy": "npx wrangler deploy --config wrangler.toml",
    "test": "vitest run",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@chainatlas/shared": "*",
    "@fastify/cors": "^11.0.1",
    "fastify": "^5.2.1",
    "viem": "^2.47.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
